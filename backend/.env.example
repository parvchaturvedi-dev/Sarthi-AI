# Copy to backend/.env and fill in. (backend/.env is git-ignored.)

# --- Auth JWT (any long random string) ---
JWT_SECRET=change-this-to-a-long-random-string

# --- Oracle auth: apex.oracle.com via ORDS REST (recommended for you) ---
# After running backend/sql/01_schema.sql + 03_ords_rest.sql in your APEX
# workspace, your base URL is https://oracleapex.com/ords/novadb/nova/auth
ORDS_BASE_URL=https://oracleapex.com/ords/novadb/nova/auth

# --- OR: direct Oracle DB (Autonomous / XE) — leave ORDS_BASE_URL blank to use this ---
# ORACLE_USER=your_db_user
# ORACLE_PASSWORD=your_db_password
# ORACLE_DSN=host:port/service_name
# ORACLE_CONFIG_DIR=C:/path/to/wallet        (Autonomous DB only)
# ORACLE_WALLET_PASSWORD=your_wallet_password (Autonomous DB only)

# --- "Continue with Google" login (Web OAuth client ID) ---
GOOGLE_LOGIN_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
