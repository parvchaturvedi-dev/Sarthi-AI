# Copy to backend/.env and fill in. (backend/.env is git-ignored.)

# --- Auth JWT (any long random string) ---
JWT_SECRET=change-this-to-a-long-random-string

# --- Accounts database: MongoDB (Atlas free tier works) ---
# Get the URI from https://cloud.mongodb.com -> Connect -> Drivers -> Python.
# Replace <password>. Leave blank to fall back to a local SQLite file for dev.
MONGODB_URI=mongodb+srv://user:<password>@cluster.xxxx.mongodb.net/?retryWrites=true&w=majority
# Optional: which database inside the cluster to use (default: sarthi)
# MONGODB_DB=sarthi

# --- "Continue with Google" login (Web OAuth client ID) ---
GOOGLE_LOGIN_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
